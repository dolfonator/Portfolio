---
const steps = [
  {
    title: 'Demo',
    text: 'We start with the clearest version of the offer, the content you already have, and the action your customer should take.'
  },
  {
    title: 'Build',
    text: 'I turn that into a fast static site with responsive layouts, SEO basics, structured data, and direct contact routes.'
  },
  {
    title: 'Live',
    text: 'The site goes online in days, not months, with the first version small enough to improve quickly after real visitors arrive.'
  }
];
---
<ol class="process-list">
  {steps.map((step) => (
    <li data-reveal>
      <div>
        <h3>{step.title}</h3>
        <p>{step.text}</p>
      </div>
    </li>
  ))}
</ol>
