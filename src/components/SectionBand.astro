---
const {
  eyebrow,
  title,
  lead,
  number,
  tone = 'paper',
  id
} = Astro.props;
---
<section class:list={['section', `band-${tone}`]} id={id}>
  <div class="container">
    {(eyebrow || title || lead || number) && (
      <header class="section-head" data-reveal>
        <span class="section-num" aria-hidden="true">{number}</span>
        <div>
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          {title && <h2>{title}</h2>}
          {lead && <p class="section-lead">{lead}</p>}
        </div>
      </header>
    )}
    <slot />
  </div>
</section>
