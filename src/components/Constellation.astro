---
interface Props {
  density?: number;
  class?: string;
}

const {
  density = 140,
  class: className = ''
} = Astro.props as Props;
---

<canvas
  class:list={['constellation', className]}
  data-constellation
  data-density={density}
  aria-hidden="true"
></canvas>

<style>
  .constellation {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

<script>
  type RGB = [number, number, number];
  type MeshNode = {
    homeX: number;
    homeY: number;
    x: number;
    y: number;
    phase: number;
    amp: number;
    speed: number;
  };
  type NavigatorWithConnection = Navigator & { connection?: { saveData?: boolean } };

  const canvases = document.querySelectorAll<HTMLCanvasElement>('canvas[data-constellation]');

  canvases.forEach((canvas) => {
    const parent = canvas.parentElement;
    const context = canvas.getContext('2d');
    if (!parent || !context) return;

    if ((navigator as NavigatorWithConnection).connection?.saveData === true) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const root = document.documentElement;
    const targetCount = Math.max(60, Math.min(220, Math.round(Number(canvas.dataset.density) || 140)));
    const interactionRadius = 170;
    const pointer = { x: 0, y: 0, active: false };
    let nodes: MeshNode[] = [];
    let cols = 0;
    let rows = 0;
    let width = 0;
    let height = 0;
    let isVisible = true;
    let animationFrame = 0;
    let resizeTimer = 0;
    let cleaned = false;
    let lastTime = 0;

    const parseColor = (value: string): RGB | null => {
      const hex = value.trim().match(/^#([\da-f]{3,8})$/i);
      if (hex) {
        let digits = hex[1];
        if (digits.length === 3 || digits.length === 4) {
          digits = digits.split('').map((digit) => digit + digit).join('');
        }
        return [
          parseInt(digits.slice(0, 2), 16),
          parseInt(digits.slice(2, 4), 16),
          parseInt(digits.slice(4, 6), 16)
        ] as RGB;
      }

      const rgb = value.trim().match(/^rgba?\(([^)]+)\)$/i);
      if (!rgb) return null;
      const channels = rgb[1].split(/[,\s/]+/).filter(Boolean).slice(0, 3);
      const values = channels.map((channel) => channel.endsWith('%')
        ? Math.round(parseFloat(channel) * 2.55)
        : parseFloat(channel));
      return values.length === 3 ? [values[0], values[1], values[2]] as RGB : null;
    };

    // Theme-aware palette, re-read every frame so a data-theme flip recolors
    // the mesh immediately. Light theme warms toward the AA-tuned amber-dark
    // and draws slightly stronger, since steel hairlines recede on pale bands.
    const readPalette = () => {
      const styles = getComputedStyle(root);
      const dark = root.dataset.theme === 'dark';
      const steel = parseColor(styles.getPropertyValue('--steel'));
      const warm = parseColor(styles.getPropertyValue(dark ? '--amber' : '--amber-dark'));
      if (!steel || !warm) return null;
      return {
        steel,
        warm,
        washAlpha: dark ? 0.05 : 0.055,
        lineAlpha: dark ? 0.16 : 0.2,
        dotAlpha: dark ? 0.5 : 0.55
      };
    };

    const mix = (cool: RGB, warm: RGB, amount: number): RGB => {
      const ratio = Math.max(0, Math.min(1, amount));
      return [
        Math.round(cool[0] + (warm[0] - cool[0]) * ratio),
        Math.round(cool[1] + (warm[1] - cool[1]) * ratio),
        Math.round(cool[2] + (warm[2] - cool[2]) * ratio)
      ];
    };

    const cssColor = (rgb: RGB) => `rgb(${rgb.join(', ')})`;

    // Nodes live on a jittered grid and wobble gently around their homes, so
    // the mesh reads as a warped quad lattice rather than a random point field.
    const seedNodes = () => {
      const cell = Math.sqrt((width * height) / targetCount) || 1;
      cols = Math.max(3, Math.round(width / cell) + 1);
      rows = Math.max(3, Math.round(height / cell) + 1);
      nodes = [];
      const jitterX = (width / (cols - 1)) * 0.3;
      const jitterY = (height / (rows - 1)) * 0.3;
      for (let row = 0; row < rows; row += 1) {
        for (let col = 0; col < cols; col += 1) {
          const homeX = (col / (cols - 1)) * width + (Math.random() - 0.5) * 2 * jitterX;
          const homeY = (row / (rows - 1)) * height + (Math.random() - 0.5) * 2 * jitterY;
          nodes.push({
            homeX,
            homeY,
            x: homeX,
            y: homeY,
            phase: Math.random() * Math.PI * 2,
            amp: 2 + Math.random() * Math.min(10, Math.min(jitterX, jitterY)),
            speed: 0.00012 + Math.random() * 0.00018
          });
        }
      }
    };

    const resizeCanvas = () => {
      const rect = canvas.getBoundingClientRect();
      if (!rect.width || !rect.height) return;
      width = rect.width;
      height = rect.height;
      seedNodes();

      const pixelRatio = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.max(1, Math.round(width * pixelRatio));
      canvas.height = Math.max(1, Math.round(height * pixelRatio));
      context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);
    };

    const warmthFor = (distance: number) => pointer.active
      ? Math.max(0, 1 - distance / interactionRadius)
      : 0;

    const segmentDistance = (pointX: number, pointY: number, start: MeshNode, end: MeshNode) => {
      const deltaX = end.x - start.x;
      const deltaY = end.y - start.y;
      const lengthSquared = deltaX * deltaX + deltaY * deltaY || 1;
      const projection = Math.max(0, Math.min(1, (
        (pointX - start.x) * deltaX + (pointY - start.y) * deltaY
      ) / lengthSquared));
      const nearestX = start.x + deltaX * projection;
      const nearestY = start.y + deltaY * projection;
      return Math.hypot(pointX - nearestX, pointY - nearestY);
    };

    const strokeEdge = (start: MeshNode, end: MeshNode, palette: NonNullable<ReturnType<typeof readPalette>>) => {
      const warmth = warmthFor(segmentDistance(pointer.x, pointer.y, start, end));
      context.beginPath();
      context.moveTo(start.x, start.y);
      context.lineTo(end.x, end.y);
      context.strokeStyle = cssColor(mix(palette.steel, palette.warm, warmth));
      context.globalAlpha = palette.lineAlpha + warmth * 0.42;
      context.lineWidth = 0.55 + warmth * 0.45;
      context.stroke();
    };

    const draw = (time: number) => {
      if (cleaned || !width || !height) return;
      const palette = readPalette();
      if (!palette) return;

      for (const node of nodes) {
        node.x = node.homeX + Math.sin(time * node.speed + node.phase) * node.amp;
        node.y = node.homeY + Math.cos(time * node.speed * 0.85 + node.phase * 1.4) * node.amp;
      }

      context.clearRect(0, 0, width, height);
      const at = (row: number, col: number) => nodes[row * cols + col];

      // Pass 1: quad facets — each warped grid cell gets a faint steel wash
      // that warms toward amber near the cursor.
      for (let row = 0; row < rows - 1; row += 1) {
        for (let col = 0; col < cols - 1; col += 1) {
          const p00 = at(row, col);
          const p10 = at(row, col + 1);
          const p11 = at(row + 1, col + 1);
          const p01 = at(row + 1, col);
          const warmth = warmthFor(Math.hypot(
            pointer.x - (p00.x + p10.x + p11.x + p01.x) / 4,
            pointer.y - (p00.y + p10.y + p11.y + p01.y) / 4
          ));
          context.beginPath();
          context.moveTo(p00.x, p00.y);
          context.lineTo(p10.x, p10.y);
          context.lineTo(p11.x, p11.y);
          context.lineTo(p01.x, p01.y);
          context.closePath();
          context.fillStyle = cssColor(mix(palette.steel, palette.warm, warmth));
          context.globalAlpha = palette.washAlpha + warmth * 0.09;
          context.fill();
        }
      }

      // Pass 2: lattice edges (each horizontal and vertical edge once).
      for (let row = 0; row < rows; row += 1) {
        for (let col = 0; col < cols; col += 1) {
          if (col < cols - 1) strokeEdge(at(row, col), at(row, col + 1), palette);
          if (row < rows - 1) strokeEdge(at(row, col), at(row + 1, col), palette);
        }
      }

      // Pass 3: cursor threads — explicit lines from the pointer to every node
      // within reach, so hovering visibly gathers the nearby mesh.
      if (pointer.active) {
        for (const node of nodes) {
          const distance = Math.hypot(pointer.x - node.x, pointer.y - node.y);
          if (distance > interactionRadius) continue;
          const pull = 1 - distance / interactionRadius;
          context.beginPath();
          context.moveTo(pointer.x, pointer.y);
          context.lineTo(node.x, node.y);
          context.strokeStyle = cssColor(mix(palette.steel, palette.warm, 0.5 + pull * 0.5));
          context.globalAlpha = 0.1 + pull * 0.38;
          context.lineWidth = 0.6 + pull * 0.5;
          context.stroke();
        }
      }

      // Pass 4: node markers as small diamonds — squares, not the sample's dots.
      for (const node of nodes) {
        const warmth = warmthFor(Math.hypot(pointer.x - node.x, pointer.y - node.y));
        const size = 1.3 + warmth * 1.1;
        context.beginPath();
        context.moveTo(node.x, node.y - size);
        context.lineTo(node.x + size, node.y);
        context.lineTo(node.x, node.y + size);
        context.lineTo(node.x - size, node.y);
        context.closePath();
        context.fillStyle = cssColor(mix(palette.steel, palette.warm, warmth));
        context.globalAlpha = palette.dotAlpha + warmth * 0.4;
        context.fill();
      }
      context.globalAlpha = 1;
    };

    const animate = (time: number) => {
      if (cleaned || !isVisible) {
        animationFrame = 0;
        return;
      }
      lastTime = time;
      draw(time);
      animationFrame = requestAnimationFrame(animate);
    };

    const startAnimation = () => {
      if (!animationFrame && isVisible) {
        animationFrame = requestAnimationFrame(animate);
      }
    };

    const stopAnimation = () => {
      if (animationFrame) cancelAnimationFrame(animationFrame);
      animationFrame = 0;
    };

    // Listen on the parent because the canvas passes pointer events through to
    // content above it.
    const onPointerMove = (event: PointerEvent) => {
      const rect = canvas.getBoundingClientRect();
      pointer.x = event.clientX - rect.left;
      pointer.y = event.clientY - rect.top;
      pointer.active = true;
    };

    const onPointerLeave = () => {
      pointer.active = false;
    };

    const onResize = () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        if (cleaned) return;
        resizeCanvas();
        draw(lastTime);
      }, 120);
    };

    let visibilityObserver: IntersectionObserver | undefined;
    if ('IntersectionObserver' in window) {
      isVisible = false;
      visibilityObserver = new IntersectionObserver((entries) => {
        const entry = entries[0];
        if (!entry) return;
        isVisible = entry.isIntersecting;
        if (isVisible) {
          resizeCanvas();
          startAnimation();
        } else {
          stopAnimation();
        }
      }, { threshold: 0 });
      visibilityObserver.observe(canvas);
    }

    let documentObserver: MutationObserver | undefined;
    const cleanup = () => {
      if (cleaned) return;
      cleaned = true;
      stopAnimation();
      window.clearTimeout(resizeTimer);
      parent.removeEventListener('pointermove', onPointerMove);
      parent.removeEventListener('pointerleave', onPointerLeave);
      window.removeEventListener('resize', onResize);
      visibilityObserver?.disconnect();
      documentObserver?.disconnect();
    };

    documentObserver = new MutationObserver(() => {
      if (!canvas.isConnected) cleanup();
    });
    documentObserver.observe(root, { childList: true, subtree: true });

    parent.addEventListener('pointermove', onPointerMove, { passive: true });
    parent.addEventListener('pointerleave', onPointerLeave, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });

    resizeCanvas();
    startAnimation();
  });
</script>
