  phone: '<path d="M7.2 4.5h3l1.2 3.7-2 1.3a10.5 10.5 0 0 0 5.1 5.1l1.3-2 3.7 1.2v3a2 2 0 0 1-2.2 2c-6.1-.4-11.7-6-12.1-12.1a2 2 0 0 1 2-2.2Z"/>',
  arrow: '<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>',
  menu: '<path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/>',
  external: '<path d="M14 5h5v5"/><path d="m19 5-8 8"/><path d="M19 14v4a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h4"/>'
} satisfies Record<IconName, string>;
---
<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={paths[name]} />
