---
import '../styles/global.css';
import Icon from '../components/Icon.astro';

const {
  title = 'Tristan Dolfo | Freelance Web Developer in Quezon City',
  description = 'Fast, polished websites for Philippine local businesses, built by Tristan in Quezon City.',
  canonical = Astro.url.pathname,
  ogImage = '/og-image.svg',
  jsonLd
} = Astro.props;

// astro.config.mjs guarantees `site` is set, so Astro.site is always defined
// here. Guard anyway rather than fall back to a wrong hardcoded URL.
const siteUrl = Astro.site;
if (!siteUrl) {
  throw new Error('Astro.site is undefined — set SITE_URL before building.');
}
const canonicalUrl = new URL(canonical, siteUrl).toString();
const ogUrl = new URL(ogImage, siteUrl).toString();

// Active-nav "you are here": a nav item is current when the path matches it.
const path = Astro.url.pathname;
const isCurrent = (href: string) => path === href || path.startsWith(href);
const navLinks = [
  { href: '/projects/', label: 'Projects' },
  { href: '/services/', label: 'Services' },
  { href: '/about/', label: 'About' }
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#14304E" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tristan Portfolio" />
    <meta property="og:locale" content="en_PH" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <script is:inline>
      // Mark JS as available before first paint. Scroll-reveal hides content
      // only under `html.js`, so no-JS visitors get everything visible.
      document.documentElement.classList.add('js');
      const savedTheme = localStorage.getItem('theme');
      const preferredTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = savedTheme || preferredTheme;
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/" aria-label="Tristan portfolio home">
          <span class="brand-mark">T</span>
          <span>Tristan Dolfo<small>Freelance web developer</small></span>
        </a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="nav" data-nav-toggle>
          <Icon name="menu" />
        </button>
        <nav class="nav" id="nav" aria-label="Primary" data-nav>
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={{ 'is-current': isCurrent(link.href) }}
              aria-current={isCurrent(link.href) ? 'page' : undefined}
            >{link.label}</a>
          ))}
          <a href="mailto:tristandolfo@gmail.com?subject=Portfolio%20inquiry">Email me</a>
          <button class="theme-toggle" type="button" aria-label="Switch color theme" data-theme-toggle>
            <span data-icon="moon"><Icon name="moon" /></span>
            <span data-icon="sun"><Icon name="sun" /></span>
          </button>
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <p>Tristan, freelance web developer in Quezon City.</p>
        <p><a href="mailto:tristandolfo@gmail.com">tristandolfo@gmail.com</a> · <a href="tel:+639998827004">0999-882-7004</a></p>
      </div>
    </footer>
    <script>
      // A quiet hello for the curious — recruiters and devs who open the console.
      console.log(
        '%cTristan · freelance web developer%c\nLiked the build? Let’s make yours. → tristandolfo@gmail.com',
        'font: 650 15px/1.5 Georgia, serif; color: #D9822B',
        'font: 400 13px/1.6 system-ui, sans-serif; color: #4A6FA5'
      );

      const nav = document.querySelector('[data-nav]');
      const toggle = document.querySelector('[data-nav-toggle]');
      const themeToggle = document.querySelector('[data-theme-toggle]');
      toggle?.addEventListener('click', () => {
        const isOpen = nav?.getAttribute('data-open') === 'true';
        nav?.setAttribute('data-open', String(!isOpen));
        toggle.setAttribute('aria-expanded', String(!isOpen));
      });

      themeToggle?.addEventListener('click', () => {
        const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = nextTheme;
        localStorage.setItem('theme', nextTheme);
      });

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduceMotion && 'IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12 });
        document.querySelectorAll('[data-reveal]').forEach((item) => observer.observe(item));
      } else {
        document.querySelectorAll('[data-reveal]').forEach((item) => item.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
