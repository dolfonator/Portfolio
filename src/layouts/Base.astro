---
import '../styles/global.css';
import Icon from '../components/Icon.astro';

const {
  title = 'Tristan Dolfo | Software Developer in Quezon City',
  description = 'Fast, polished sites and systems for businesses. Built by Tristan. Quezon City.',
  canonical = Astro.url.pathname,
  ogImage = '/og-image.png',
  jsonLd
} = Astro.props;

// astro.config.mjs guarantees `site` is set, so Astro.site is always defined
// here. Guard anyway rather than fall back to a wrong hardcoded URL.
const siteUrl = Astro.site;
if (!siteUrl) {
  throw new Error('Astro.site is undefined — set SITE_URL before building.');
}
const canonicalUrl = new URL(canonical, siteUrl).toString();
const ogUrl = new URL(ogImage, siteUrl).toString();

// Active-nav "you are here": a nav item is current when the path matches it.
const path = Astro.url.pathname;
const isCurrent = (href: string) => path === href || path.startsWith(href);
const navLinks = [
  { href: '/projects/', label: 'Projects' },
  { href: '/services/', label: 'Services' },
  { href: '/about/', label: 'About' }
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#14304E" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tristan Portfolio" />
    <meta property="og:locale" content="en_PH" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <script is:inline>
      // Mark JS as available before first paint. Scroll-reveal hides content
      // only under `html.js`, so no-JS visitors get everything visible.
      document.documentElement.classList.add('js');
      const savedTheme = localStorage.getItem('theme');
      const preferredTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = savedTheme || preferredTheme;
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/" aria-label="Tristan portfolio home">
          <span class="brand-mark">T</span>
          <span>Tristan Dolfo<small>Software developer</small></span>
        </a>
        <button class="theme-toggle" type="button" aria-label="Switch to dark theme" data-theme-toggle>
          <span data-icon="moon"><Icon name="moon" /></span>
          <span data-icon="sun"><Icon name="sun" /></span>
        </button>
        <button class="nav-toggle" type="button" aria-label="Open navigation" aria-expanded="false" aria-controls="nav" data-nav-toggle>
          <span data-icon="menu"><Icon name="menu" /></span>
          <span data-icon="close"><Icon name="close" /></span>
        </button>
        <nav class="nav" id="nav" aria-label="Primary" data-nav>
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={{ 'is-current': isCurrent(link.href) }}
              aria-current={isCurrent(link.href) ? 'page' : undefined}
            >{link.label}</a>
          ))}
          <a class="nav-cta" href="https://mail.google.com/mail/?view=cm&fs=1&to=tristandolfo@gmail.com&su=Portfolio%20inquiry" target="_blank" rel="noopener">Email me</a>
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-primary">
          <p class="footer-signoff">Personally crafted creations, just like this site.</p>
          <div class="footer-actions">
            <a class="footer-contact" href="https://mail.google.com/mail/?view=cm&fs=1&to=tristandolfo@gmail.com&su=Portfolio%20inquiry" target="_blank" rel="noopener">Email me</a>
            <a class="footer-contact" href="tel:+639998827004">0999-882-7004</a>
            <a class="footer-social" href="https://github.com/dolfonator" target="_blank" rel="noopener" aria-label="Tristan Dolfo on GitHub">
              <Icon name="github" />
            </a>
            <a class="footer-social" href="https://www.facebook.com/tristan.dolfo.7" target="_blank" rel="noopener" aria-label="Tristan Dolfo on Facebook">
              <Icon name="facebook" />
            </a>
          </div>
        </div>
        <div class="footer-secondary">
          <nav class="footer-nav" aria-label="Footer">
            {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
          </nav>
          <p>Quezon City, Philippines · usually replies within a day</p>
        </div>
      </div>
    </footer>
    <script>
      // A lil hello for the curious recruiters and devs who open the console.
      console.log(
        '%cTristan · software developer%c\nLiked the build? Let’s make yours. → tristandolfo@gmail.com',
        'font: 650 15px/1.5 Georgia, serif; color: #D9822B',
        'font: 400 13px/1.6 system-ui, sans-serif; color: #4A6FA5'
      );

      const nav = document.querySelector<HTMLElement>('[data-nav]');
      const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
      const themeToggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');

      const handleNavKeydown = (event: KeyboardEvent) => {
        if (event.key === 'Escape') closeNav(true);
      };

      const handleOutsideClick = (event: MouseEvent) => {
        const target = event.target;
        if (target instanceof Node && !nav?.contains(target) && !toggle?.contains(target)) {
          closeNav(true);
        }
      };

      const setNavOpen = (isOpen: boolean) => {
        nav?.setAttribute('data-open', String(isOpen));
        toggle?.setAttribute('aria-expanded', String(isOpen));
        toggle?.setAttribute('aria-label', isOpen ? 'Close navigation' : 'Open navigation');
        if (isOpen) {
          document.addEventListener('keydown', handleNavKeydown);
          document.addEventListener('click', handleOutsideClick);
        } else {
          document.removeEventListener('keydown', handleNavKeydown);
          document.removeEventListener('click', handleOutsideClick);
        }
      };

      const closeNav = (returnFocus = false) => {
        if (nav?.getAttribute('data-open') !== 'true') return;
        setNavOpen(false);
        if (returnFocus) toggle?.focus();
      };

      toggle?.addEventListener('click', () => {
        setNavOpen(nav?.getAttribute('data-open') !== 'true');
      });

      nav?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => closeNav());
      });

      const updateThemeLabel = () => {
        const isDark = document.documentElement.dataset.theme === 'dark';
        themeToggle?.setAttribute('aria-label', isDark ? 'Switch to light theme' : 'Switch to dark theme');
      };

      updateThemeLabel();

      themeToggle?.addEventListener('click', () => {
        const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = nextTheme;
        localStorage.setItem('theme', nextTheme);
        updateThemeLabel();
      });

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduceMotion && 'IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12 });
        document.querySelectorAll('[data-reveal]').forEach((item) => observer.observe(item));
      } else {
        document.querySelectorAll('[data-reveal]').forEach((item) => item.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
