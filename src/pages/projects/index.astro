---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';

type Project = CollectionEntry<'projects'>;

const projects: Project[] = (await getCollection('projects'))
  .sort((a: Project, b: Project) => a.data.displayOrder - b.data.displayOrder);
const commercialProjects = projects.filter((project) => project.data.kind === 'commercial');
const personalProjects = projects.filter((project) => project.data.kind === 'personal');
const [lead, ...supporting] = commercialProjects;
const commercialCount = commercialProjects.length;
const personalCount = personalProjects.length;
const projectMix = `${commercialCount} commercial ${commercialCount === 1 ? 'site' : 'sites'} and ${personalCount} personal ${personalCount === 1 ? 'commission' : 'commissions'}`;
---
<Base title="Projects | Tristan" description="Projects by Tristan: commercial websites and personal commissions, all live and clickable." canonical="/projects/">
  <section class="section band-mist">
    <div class="container">
      <header class="page-head" data-reveal>
        <p class="page-kicker"><span class="hero-dot" aria-hidden="true"></span>{projects.length} builds — live and clickable</p>
        <h1 class="page-title">Sites that look like the <span class="hero-mark">business</span>, not the template.</h1>
        <p class="page-lead">{projectMix}, each art-directed for the audience it serves. Every project opens as a real, working site.</p>
      </header>
      <div class="projects-stack">
        {lead && <ProjectCard project={lead} featured headingLevel={2} />}
        {supporting.length > 0 && (
          <div class="commercial-supporting">
            {supporting.map((project) => <ProjectCard project={project} compact headingLevel={2} />)}
          </div>
        )}
      </div>
      {personalProjects.length > 0 && (
        <section class="commissions" aria-labelledby="commissions-title">
          <header class="commissions-head" data-reveal>
            <p>Personal Commissions</p>
            <h2 id="commissions-title">Specific builds for specific needs.</h2>
          </header>
          <div class="commission-list">
            {personalProjects.map((project) => <ProjectCard project={project} compact headingLevel={3} />)}
          </div>
        </section>
      )}
    </div>
  </section>
</Base>
