---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';

type Project = CollectionEntry<'projects'>;

const projects: Project[] = (await getCollection('projects')).sort((a: Project, b: Project) => {
  if (Number(b.data.featured) !== Number(a.data.featured)) return Number(b.data.featured) - Number(a.data.featured);
  return b.data.year - a.data.year;
});

const [lead, ...rest] = projects;
---
<Base title="Projects | Tristan" description="Projects by Tristan: commercial website demos and personal static builds." canonical="/projects/">
  <section class="section band-mist">
    <div class="container">
      <header class="page-head" data-reveal>
        <p class="page-kicker"><span class="hero-dot" aria-hidden="true"></span>Three builds — live and clickable</p>
        <h1 class="page-title">Sites that look like the <span class="hero-mark">business</span>, not the template.</h1>
        <p class="page-lead">Two Business-tier concept demos and a personal microsite — each art-directed for the brand it serves. Every card opens the real, working site in a new tab.</p>
      </header>
      <div class="projects-stack">
        {lead && <ProjectCard project={lead} featured headingLevel={2} />}
        {rest.length > 0 && (
          <div class="grid two">
            {rest.map((project) => <ProjectCard project={project} headingLevel={2} />)}
          </div>
        )}
      </div>
    </div>
  </section>
</Base>
