---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CTA from '../../components/CTA.astro';
import Constellation from '../../components/Constellation.astro';
import ProjectCard from '../../components/ProjectCard.astro';

type Project = CollectionEntry<'projects'>;

const projects: Project[] = (await getCollection('projects'))
  .sort((a: Project, b: Project) => a.data.displayOrder - b.data.displayOrder);
const commercialProjects = projects.filter((project) => project.data.kind === 'commercial');
const personalProjects = projects.filter((project) => project.data.kind === 'personal');
const commercialCount = commercialProjects.length;
const personalCount = personalProjects.length;
const projectMix = `${commercialCount} commercial ${commercialCount === 1 ? 'site' : 'sites'} and ${personalCount} personal ${personalCount === 1 ? 'commission' : 'commissions'}`;
---
<Base title="Projects | Tristan" description="Projects by Tristan: commercial websites and personal commissions, all live and clickable." canonical="/projects/">
  <section class="section starfield">
    <Constellation density={200} islandLimit={4} class="fade-edge" />
    <div class="container">
      <header class="page-head" data-reveal>
        <p class="page-kicker"><span class="hero-dot" aria-hidden="true"></span>{projects.length} builds, open and explorable</p>
        <h1 class="page-title">Sites that look like the <span class="hero-mark">business</span>, not the template.</h1>
        <p class="page-lead">{projectMix}, each art-directed for the audience it serves. Every project opens as a real site or a real repo. Nothing here is a mockup.</p>
      </header>
      <div class="commercial-supporting">
        {commercialProjects.map((project) => <ProjectCard project={project} compact headingLevel={2} />)}
      </div>
    </div>
  </section>

  {personalProjects.length > 0 && (
    <section class="section band-paper commissions" aria-labelledby="commissions-title">
      <div class="container">
        <header class="commissions-head" data-reveal>
          <p>Personal Commissions</p>
          <h2 id="commissions-title">Specific builds for specific needs.</h2>
        </header>
        <div class="commission-list">
          {personalProjects.map((project) => <ProjectCard project={project} compact headingLevel={3} />)}
        </div>
      </div>
    </section>
  )}

  <section class="section band-dark closer">
    <Constellation />
    <div class="container closer-inner">
      <div class="text-scrim">
        <p class="closer-kicker">Seen enough?</p>
        <h2 class="closer-title">Tell me which one is <span class="closer-mark">closest</span> to your business.</h2>
        <CTA label="Email me" showPhone />
      </div>
    </div>
  </section>
</Base>
