---
import Base from '../layouts/Base.astro';
import CTA from '../components/CTA.astro';
import Constellation from '../components/Constellation.astro';
import Icon from '../components/Icon.astro';

const tiers = [
  {
    tag: 'Starter',
    title: 'A polished one-page presence',
    bestFor: 'a café or clinic that just needs to be found and called.',
    subject: 'Starter website quote',
    ctaLabel: 'Start a Starter conversation',
    points: [
      'Hero, offer, proof, location and contact, one clear CTA',
      'Mobile-first responsive design',
      'SEO basics and social preview metadata',
      'Fast static deployment',
    ],
  },
  {
    tag: 'Business',
    title: 'Your full menu or service story, on-site',
    bestFor: 'a restaurant or service business with real content to show, such as a menu, services, or a gallery.',
    subject: 'Business website quote',
    ctaLabel: 'Start a Business conversation',
    points: [
      'Multi-section or multi-page site',
      'Menu or services, gallery, reviews, FAQs',
      'Local-business structured data',
      'Clear ordering, booking, or inquiry routes',
    ],
  },
  {
    tag: 'Premier',
    title: 'Custom builds for specific workflows',
    bestFor: 'a business that needs an interactive tool or system, not a brochure.',
    subject: 'Premier website quote',
    ctaLabel: 'Start a Premier conversation',
    points: [
      'Interactive tools or richer content systems',
      'Serverless functions when the site needs state',
      'Custom performance and accessibility passes',
      'Launch support and post-launch iteration',
    ],
  },
];

const compose = (subject: string) => `https://mail.google.com/mail/?view=cm&fs=1&to=tristandolfo@gmail.com&su=${encodeURIComponent(subject)}`;
---
<Base title="Services | Tristan" description="Website packages for Philippine local businesses, shown by outcome and scope without public pricing." canonical="/services/">
  <section class="section band-paper">
    <Constellation />
    <div class="container">
      <header class="page-head" data-reveal>
        <p class="page-kicker"><span class="hero-dot" aria-hidden="true"></span>Website packages</p>
        <h1 class="page-title">Choose the <span class="hero-mark">shape</span> of the site.</h1>
        <p class="page-lead">Every build targets one clear customer action, ships fast, and comes with an optional care plan after launch. No public pricing. The right scope depends on your content and how much the site needs to do.</p>
      </header>
      <div class="svc-tiers">
        {tiers.map((tier) => (
          <article class:list={['svc-tier', { 'is-recommended': tier.tag === 'Business' }]} data-reveal>
            <div class="svc-head">
              <div class="svc-labels">
                <span class="svc-tag">{tier.tag}</span>
                {tier.tag === 'Business' && <span class="svc-recommendation">Most owners start here</span>}
              </div>
              <h2>{tier.title}</h2>
              <p class="svc-fit"><strong>Best for:</strong> {tier.bestFor}</p>
            </div>
            <div class="svc-detail">
              <ul class="svc-list">
                {tier.points.map((point) => <li>{point}</li>)}
              </ul>
              <a class:list={['button', { secondary: tier.tag !== 'Business' }]} href={compose(tier.subject)} target="_blank" rel="noopener">
                {tier.ctaLabel}
                <Icon name="arrow" />
              </a>
            </div>
          </article>
        ))}
      </div>
      <div class="svc-includes" data-reveal>
        <p class="svc-includes-label">Every tier includes</p>
        <ul aria-label="Included with every website tier">
          <li class="pill">Mobile-first build</li>
          <li class="pill">SEO basics</li>
          <li class="pill">Structured data</li>
          <li class="pill">Fast static deployment</li>
        </ul>
        <p class="svc-includes-plus">+ Optional care and growth plans after launch</p>
      </div>
    </div>
  </section>

  <section class="section band-dark closer">
    <Constellation />
    <div class="container closer-inner">
      <p class="closer-kicker">After launch</p>
      <h2 class="closer-title">Every site can stay <span class="closer-mark">maintained.</span></h2>
      <p class="section-lead">Updates, small fixes, SEO improvements, and growth work, scoped once the first version is live.</p>
      <CTA label="Email me" showPhone />
    </div>
  </section>
</Base>
