---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import CTA from '../components/CTA.astro';
import SectionBand from '../components/SectionBand.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import Icon from '../components/Icon.astro';

type Project = CollectionEntry<'projects'>;

const projects: Project[] = await getCollection('projects');
const featured = projects
  .filter((project: Project) => project.data.featured)
  .sort((a: Project, b: Project) => a.data.title.localeCompare(b.data.title));

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Tristan',
    email: 'mailto:tristandolfo@gmail.com',
    telephone: '+639998827004',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Quezon City',
      addressCountry: 'PH'
    },
    jobTitle: 'Freelance Web Developer'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'Tristan Web Development',
    areaServed: 'Philippines',
    email: 'mailto:tristandolfo@gmail.com',
    telephone: '+639998827004',
    serviceType: ['Business websites', 'Restaurant websites', 'Static web development']
  }
];
---
<Base jsonLd={jsonLd}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="hero-kicker"><span class="hero-dot" aria-hidden="true"></span>Quezon City · freelance web developer</p>
        <h1 class="hero-title">Fast websites for <span class="hero-mark">local businesses.</span></h1>
        <p class="hero-sub">I build focused, polished sites for restaurants, cafés, clinics, and small teams — the kind where a customer understands the offer and acts in seconds.</p>
        <CTA showPhone />
      </div>
      <aside class="works panel" aria-label="Selected work">
        <p class="works-label">Selected work</p>
        <ol class="works-list">
          {featured.map((project, i) => (
            <li>
              <a class="work" href={project.data.liveUrl} target="_blank" rel="noopener">
                <span class="work-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span class="work-text">
                  <strong>{project.data.title}</strong>
                  <span>{project.data.clientType}</span>
                </span>
                <Icon name="external" />
              </a>
            </li>
          ))}
        </ol>
        <p class="works-foot">Static-first builds — instant loads, portable hosting.</p>
      </aside>
    </div>
  </section>

  <SectionBand tone="mist">
    <header class="sec-head-bold">
      <h2>Business clarity, with craft in the details.</h2>
      <p class="sec-lead">Two Business-tier concept sites — a creative studio and a diner — each art-directed to look like the business it's for, not a template.</p>
    </header>
    <div class="grid two">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </SectionBand>

  <SectionBand tone="paper">
    <header class="sec-head-bold">
      <h2>Website packages, by outcome.</h2>
      <p class="sec-lead">No public pricing — the right scope depends on your content, your urgency, and how much the site needs to do.</p>
    </header>
    <div class="tier-list">
      <article class="tier">
        <div class="tier-head">
          <p class="tier-tag">Starter</p>
          <h3>One-page presence</h3>
        </div>
        <p>A polished homepage for a clear offer, essential trust signals, location and contact details, and one direct action.</p>
      </article>
      <article class="tier">
        <div class="tier-head">
          <p class="tier-tag">Business</p>
          <h3>Full business site</h3>
        </div>
        <p>Menu or services, gallery, reviews, FAQs, structured data, and stronger routes for inquiries, booking, or ordering.</p>
      </article>
      <article class="tier">
        <div class="tier-head">
          <p class="tier-tag">Premier</p>
          <h3>Custom build</h3>
        </div>
        <p>Special interfaces, content systems, shared state, automation-friendly workflows, and more technical polish.</p>
      </article>
    </div>
    <div class="sec-cta">
      <CTA label="Email me for a quote" subject="Website quote inquiry" />
    </div>
  </SectionBand>

  <SectionBand tone="sky">
    <header class="sec-head-bold">
      <h2>A build should move.</h2>
      <p class="sec-lead">The v1 goal is a live, useful site in days — then improvement from real feedback.</p>
    </header>
    <div class="split">
      <div class="panel panel-pad">
        <h3>Demo to live, without the fog.</h3>
        <p>One clear offer, one primary action, a fast static build, and enough structure that the site can grow after launch.</p>
      </div>
      <ProcessSteps />
    </div>
  </SectionBand>

  <SectionBand tone="paper">
    <header class="sec-head-bold">
      <h2>Small sites, built with product judgment.</h2>
    </header>
    <div class="split">
      <div class="placeholder-portrait">
        <!-- PLACEHOLDER: portrait -->
        Portrait placeholder
      </div>
      <div class="panel panel-pad">
        <!-- PLACEHOLDER: bio -->
        <p>I’m Tristan, a freelance web developer in Quezon City. I build quiet, fast, practical websites for local businesses, with enough care in the design and code that the first version can become a real sales asset.</p>
        <div class="about-actions">
          <a class="button secondary" href="/about/">More about me</a>
        </div>
      </div>
    </div>
  </SectionBand>

  <section class="section band-dark closer">
    <div class="container closer-inner">
      <p class="closer-kicker">Ready when you are</p>
      <h2 class="closer-title">Tell me what you need your site to <span class="closer-mark">do.</span></h2>
      <CTA label="Email me" showPhone />
    </div>
  </section>
</Base>
