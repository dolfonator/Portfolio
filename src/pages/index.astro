---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import CTA from '../components/CTA.astro';
import SectionBand from '../components/SectionBand.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import Icon from '../components/Icon.astro';

type Project = CollectionEntry<'projects'>;

const projects: Project[] = await getCollection('projects');
const featured = projects
  .filter((project: Project) => project.data.featured)
  .sort((a: Project, b: Project) => a.data.displayOrder - b.data.displayOrder);
const [leadProject, ...supportingProjects] = featured;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Tristan',
    email: 'mailto:tristandolfo@gmail.com',
    telephone: '+639998827004',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Quezon City',
      addressCountry: 'PH'
    },
    jobTitle: 'Freelance Web Developer'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'Tristan Web Development',
    areaServed: 'Philippines',
    email: 'mailto:tristandolfo@gmail.com',
    telephone: '+639998827004',
    serviceType: ['Business websites', 'Restaurant websites', 'Static web development']
  }
];
---
<Base jsonLd={jsonLd}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="hero-kicker"><span class="hero-dot" aria-hidden="true"></span>Quezon City · freelance web developer</p>
        <h1 class="hero-title">Fast websites for <span class="hero-mark">local businesses.</span></h1>
        <p class="hero-sub">I build focused, polished sites for restaurants, cafés, clinics, and small teams — the kind where a customer understands the offer and acts in seconds.</p>
        <CTA showPhone />
      </div>
      <aside class="works panel" aria-label="Selected work">
        <p class="works-label">Selected work</p>
        <ol class="works-list">
          {featured.map((project, i) => (
            <li>
              <a class="work" href={project.data.liveUrl} target="_blank" rel="noopener">
                <span class="work-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span class="work-text">
                  <strong>{project.data.title}</strong>
                  <span>{project.data.clientType}</span>
                </span>
                <Icon name="external" />
              </a>
            </li>
          ))}
        </ol>
        <p class="works-foot">Three distinct briefs, each designed around the business or story it serves.</p>
      </aside>
    </div>
  </section>

  <SectionBand tone="mist">
    <header class="sec-head-bold">
      <h2>Different stories need different visual systems.</h2>
      <p class="sec-lead">A caterer, a production studio, and a shared birthday monograph — each working site is shaped around its own audience and next action.</p>
    </header>
    <div class="projects-stack home-projects">
      {leadProject && <ProjectCard project={leadProject} featured />}
      {supportingProjects.length > 0 && (
        <div class="grid two">
          {supportingProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      )}
    </div>
  </SectionBand>

  <SectionBand tone="sky">
    <header class="sec-head-bold">
      <h2>From the right scope to a useful launch.</h2>
      <p class="sec-lead">Start with the outcome the business needs, then build only what earns its place.</p>
    </header>
    <div class="split scope-process">
      <div class="scope-copy">
        <h3>One-page presence, full business site, or a focused custom build.</h3>
        <p>The package follows the content, urgency, and customer action — not a feature checklist. Each option stays portable and easy to maintain.</p>
        <a class="button secondary" href="/services/">See website packages</a>
      </div>
      <ProcessSteps />
    </div>
  </SectionBand>

  <section class="section band-dark closer">
    <div class="container closer-inner">
      <p class="closer-kicker">Ready when you are</p>
      <h2 class="closer-title">Tell me what you need your site to <span class="closer-mark">do.</span></h2>
      <CTA label="Email me" showPhone />
    </div>
  </section>
</Base>
