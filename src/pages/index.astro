---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import CTA from '../components/CTA.astro';
import Constellation from '../components/Constellation.astro';
import SectionBand from '../components/SectionBand.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import Icon from '../components/Icon.astro';

type Project = CollectionEntry<'projects'>;

const projects: Project[] = await getCollection('projects');
const projectCount = projects.length;
const featured = projects
  .filter((project: Project) => project.data.featured)
  .sort((a: Project, b: Project) => a.data.displayOrder - b.data.displayOrder);
const [leadProject, ...supportingProjects] = featured;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Tristan',
    email: 'mailto:tristandolfo@gmail.com',
    telephone: '+639998827004',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Quezon City',
      addressCountry: 'PH'
    },
    jobTitle: 'Freelance Web Developer'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'Tristan Web Development',
    areaServed: 'Philippines',
    email: 'mailto:tristandolfo@gmail.com',
    telephone: '+639998827004',
    serviceType: ['Business websites', 'Restaurant websites', 'Static web development']
  }
];
---
<Base jsonLd={jsonLd}>
  <section class="hero">
    <Constellation />
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="hero-kicker"><span class="hero-dot" aria-hidden="true"></span>Quezon City · freelance web developer</p>
        <h1 class="hero-title">Sites and systems for your <span class="hero-mark">every need.</span></h1>
        <p class="hero-sub">I build polished and reliable sites and management systems for restaurants, cafés, small teams, and just about anyone who needs software or tech help.</p>
        <CTA showPhone />
        <p class="hero-trust"><span class="hero-trust-count">{projectCount}</span> builds · Quezon City · replies within a day</p>
      </div>
      <aside class="works panel" aria-label="Selected work">
        <p class="works-label">Selected work</p>
        <ol class="works-list">
          {featured.map((project, i) => (
            <li>
              <a
                class="work"
                href={project.data.liveUrl ?? project.data.repoUrl}
                target="_blank"
                rel="noopener"
                aria-label={`${project.data.title} — ${project.data.liveUrl ? 'open live site' : 'view source on GitHub'} (opens in new tab)`}
              >
                <span class="work-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span class="work-text">
                  <strong>{project.data.title}</strong>
                  <span>{project.data.clientType}</span>
                </span>
                <Icon name="external" />
              </a>
            </li>
          ))}
        </ol>
        <p class="works-foot">{featured.length} distinct briefs, each designed around the business or story it serves.</p>
      </aside>
    </div>
  </section>

  <SectionBand tone="mist">
    <header class="sec-head-bold">
      <h2>Different stories need different visual systems.</h2>
      <p class="sec-lead">A caterer and a production studio's online presence; a café dashboard system; and personal commissions. Each working product is shaped around its own client and audience.</p>
    </header>
    <div class="projects-stack home-projects">
      {leadProject && <ProjectCard project={leadProject} featured />}
      {supportingProjects.length > 0 && (
        <div class="grid home-supporting-grid">
          {supportingProjects.map((project) => <ProjectCard project={project} compact />)}
        </div>
      )}
    </div>
  </SectionBand>

  <SectionBand tone="sky">
    <header class="sec-head-bold">
      <h2>From the right scope to a successful launch.</h2>
      <p class="sec-lead">I start with what the business needs, then I build what is rightfully appropriate.</p>
    </header>
    <div class="split scope-process">
      <div class="scope-copy">
        <h3>One-page presence, full business site, or a focused custom build.</h3>
        <p>Each package follows the content, urgency, and customer actions for each client. Every successful deploy stays portable and easy to maintain.</p>
        <a class="button secondary" href="/services/">See website packages</a>
      </div>
      <ProcessSteps />
    </div>
  </SectionBand>

  <section class="section band-dark closer">
    <Constellation />
    <div class="container closer-inner">
      <p class="closer-kicker">Ready when you are!</p>
      <h2 class="closer-title">Tell me what you need for your <span class="closer-mark">online presence.</span></h2>
      <CTA label="Email me" showPhone />
      <p class="closer-note">No forms, no pressure. A plain email describing your business is enough. I reply within a day.</p>
    </div>
  </section>
</Base>
