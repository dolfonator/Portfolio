---
import Base from '../layouts/Base.astro';
import CTA from '../components/CTA.astro';
import Icon from '../components/Icon.astro';

const principles = [
  {
    title: 'Clear offer',
    body: 'The page should explain what the business does, who it helps, and what visitors should do next without making wasting time.',
    projectName: "Herminia's Food Catering",
    evidenceHref: 'https://herminias-catering.vercel.app/',
  },
  {
    title: 'Fast, portable build',
    body: 'Lean HTML, CSS, JavaScript, and Astro keep the site quick on mobile and easy to move between practical hosting options.',
    projectName: 'Justdiz Preproductions',
    evidenceHref: 'https://justdiz-preproductions.vercel.app/',
  },
  {
    title: 'Room to grow',
    body: 'The first version stays focused, with enough structure to add richer content or a small custom system when the business needs it.',
    projectName: 'The Big Thirty',
    evidenceHref: 'https://bday-public.netlify.app/',
  },
];

const stackGroups = [
  { label: 'Languages', items: ['Python', 'JavaScript', 'TypeScript'] },
  { label: 'Frontend', items: ['React', 'Next.js', 'Astro'] },
  { label: 'Backend', items: ['Django', 'FastAPI', 'Node.js', 'n8n', 'Supabase'] },
  { label: 'Agentic Tools', items: ['Claude', 'Codex', 'SuperGrok'], accent: true },
  { label: 'Embedded', items: ['ESP32', 'Arduino', 'Raspberry Pi', 'C++'] },
];
---
<Base title="About | Tristan" description="About Tristan, a freelance software developer in Quezon City building reliable sites and systems for various businesses, and specific needs." canonical="/about/">
  <section class="section band-mist">
    <div class="container about-masthead">
      <div class="about-identity">
        <header class="page-head" data-reveal>
          <p class="page-kicker"><span class="hero-dot" aria-hidden="true"></span>Quezon City · software developer</p>
          <h1 class="page-title">A practical partner for <span class="hero-mark">small-business</span> sites.</h1>
        </header>
        <div class="about-profile" data-reveal>
          <div class="about-monogram" role="img" aria-label="Tristan monogram">
            <span aria-hidden="true">T</span>
            <i aria-hidden="true"></i>
          </div>
          <div class="about-profile-notes">
            <blockquote>Make the offer clear, make the site fast, make the next action obvious.</blockquote>
            <dl class="about-facts">
              <div><dt>Based in</dt><dd>Quezon City, Philippines</dd></div>
              <div>
                <dt>GitHub</dt>
                <dd>
                  <a href="https://github.com/dolfonator" target="_blank" rel="noopener">
                    <Icon name="github" />
                    dolfonator
                  </a>
                </dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
      <div class="about-intro" data-reveal>
        <div class="about-bio">
          <p class="about-lede">I’m Tristan, a software developer in Quezon City. I build fast, polished, and reliable websites and systems for various businesses.</p>
          <p>My working style is simple: make the offer clear, make the site/system fast, and make you feel secured in your product. For clients who need more than a brochure, I build small interactive systems with serverless APIs and meticuluous frontend behavior.</p>
          <CTA showPhone subject="Portfolio inquiry" class="about-cta" />
        </div>
      </div>
    </div>
  </section>

  <section class="section band-paper">
    <div class="container">
      <header class="sec-head-bold" data-reveal>
        <h2>What I build with.</h2>
      </header>
      <div class="tech-list" data-reveal>
        {stackGroups.map((group) => (
          <div class="tech-row">
            <h3 class:list={{ 'is-accent': group.accent }}>{group.label}</h3>
            <ul class="stack" aria-label={`${group.label} tools`}>
              {group.items.map((item) => <li class="pill">{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section band-paper">
    <div class="container">
      <header class="sec-head-bold" data-reveal>
        <h2>How I approach the work.</h2>
      </header>
      <div class="principles-list">
        {principles.map((principle) => (
          <article class="principle" data-reveal>
            <div class="principle-head">
              <h3>{principle.title}</h3>
            </div>
            <div class="principle-detail">
              <p>{principle.body}</p>
              <a class="principle-evidence" href={principle.evidenceHref} target="_blank" rel="noopener">
                See it in → {principle.projectName}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
