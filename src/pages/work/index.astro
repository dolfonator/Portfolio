---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SectionBand from '../../components/SectionBand.astro';
import ProjectCard from '../../components/ProjectCard.astro';

type Project = CollectionEntry<'projects'>;

const projects: Project[] = (await getCollection('projects')).sort((a: Project, b: Project) => {
  if (Number(b.data.featured) !== Number(a.data.featured)) return Number(b.data.featured) - Number(a.data.featured);
  return b.data.year - a.data.year;
});
---
<Base title="Work | Tristan" description="Portfolio work by Tristan: commercial website demos and personal static experiments." canonical="/work/">
  <SectionBand number="01" eyebrow="Work" title="Selected sites and experiments." lead="Brief project notes with direct links to the live websites and archived demos." tone="mist">
    <div class="grid two">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </SectionBand>
</Base>
